DATABASE_URL="postgresql://mytv:mytv@localhost:5433/mytv?schema=public"
PORT=3001

# Session auth (see docs/auth.md) — leave BOTH unset for local dev: the
# session gate is entirely disabled without APP_PASSWORD, matching the
# existing DevUserMiddleware no-friction local experience. A real deployment
# (Railway) must set both.
# APP_PASSWORD: the one shared login password.
# SESSION_SECRET: random signing key for the session JWT — generate with
# `openssl rand -base64 32` or similar, never reuse across environments.
APP_PASSWORD=
SESSION_SECRET=

# The mobile PWA's deployed origin (e.g. https://mytv-mobile.up.railway.app),
# comma-separated if more than one. Required alongside APP_PASSWORD — the
# session cookie is SameSite=None (cross-subdomain), which browsers refuse
# to accept from a CORS response with the wildcard/reflected-origin
# behavior main.ts falls back to when this is unset. Unset locally, where
# that permissive fallback matches the previous app.enableCors() behavior.
CORS_ORIGIN=

# Trakt API client_id (from a registered app at https://trakt.tv/oauth/applications).
# Only used for public GET endpoints (search/shows) — no OAuth token needed.
# Required by trakt-enrichment/run-enrichment-dry-run.ts.
TRAKT_CLIENT_ID=

# TMDb credentials (from https://www.themoviedb.org/settings/api).
# TMDB_ACCESS_TOKEN is the v4 "API Read Access Token" used as a Bearer token
# by trakt-enrichment's TMDb dry-run; TMDB_API_KEY is the legacy v3 key,
# recorded for reference but not required if the access token is set.
TMDB_API_KEY=
TMDB_ACCESS_TOKEN=