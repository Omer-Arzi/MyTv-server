{
  "name": "my-tv-server",
  "version": "0.1.0",
  "description": "Personal TV tracking app - backend (NestJS + Prisma + PostgreSQL)",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "prisma generate && nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "seed:demo:destructive": "ts-node prisma/seed-demo.ts",
    "prisma:backfill-status-model": "ts-node prisma/backfill-status-model.ts",
    "postinstall": "prisma generate",
    "test": "jest",
    "import:tvtime": "ts-node import-tvtime/run.ts",
    "import:tvtime:dry-run": "ts-node import-tvtime/run.ts --dry-run",
    "trakt:backfill-tvtime-show-id": "ts-node trakt-enrichment/run-backfill.ts",
    "trakt:enrichment-dry-run": "ts-node trakt-enrichment/run-enrichment-dry-run.ts",
    "tmdb:enrichment-dry-run": "ts-node tmdb-enrichment/run-enrichment-dry-run.ts",
    "tmdb:apply-plan": "ts-node tmdb-enrichment/run-apply-plan.ts",
    "tmdb:enrichment-apply": "ts-node tmdb-enrichment/run-apply-plan.ts",
    "next-episode:backfill": "ts-node next-episode-backfill/run-backfill.ts",
    "episode-refresh:dry-run": "ts-node episode-release-refresh/run-refresh.ts",
    "episode-refresh:apply-dry-run": "ts-node episode-release-refresh/run-apply-refresh.ts",
    "episode-refresh:apply": "ts-node episode-release-refresh/run-apply-refresh.ts --apply-episode-insert",
    "progress-reconciliation:dry-run": "ts-node episode-release-refresh/run-progress-reconciliation.ts",
    "progress-reconciliation:apply": "ts-node episode-release-refresh/run-progress-reconciliation.ts --apply",
    "watch-next:released-episode-audit": "ts-node watch-next-audit/run-released-episode-audit.ts",
    "library-health:report": "ts-node library-health/run-health-report.ts",
    "library-health:incomplete-catalog": "ts-node library-health/run-incomplete-catalog-investigation.ts",
    "library-health:missing-provider-candidates": "ts-node library-health/run-missing-provider-candidates.ts",
    "library-health:provider-confirmation": "ts-node library-health/run-provider-confirmation.ts",
    "library-health:provider-confirmation-dry-run": "ts-node library-health/run-provider-confirmation-dry-run.ts",
    "library-health:apply-friends-tvmaze": "ts-node library-health/run-apply-provider-confirmation-friends.ts",
    "library-health:pipeline": "ts-node library-health/run-provider-confirmation-pipeline.ts",
    "library-health:pipeline-apply": "ts-node library-health/run-provider-confirmation-pipeline.ts --apply-safe-confirmed",
    "library-health:backfill-tmdb-ids": "ts-node library-health/run-backfill-tmdb-external-ids.ts",
    "library-health:backfill-tmdb-ids-apply": "ts-node library-health/run-backfill-tmdb-external-ids.ts --apply-tmdb-id-backfill",
    "library-health:backfill-provider-decisions": "ts-node library-health/run-backfill-provider-decisions.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv-parse": "^7.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.2",
    "dotenv": "^17.4.2",
    "jest": "^30.4.2",
    "prisma": "^5.22.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
