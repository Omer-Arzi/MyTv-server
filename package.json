{
  "name": "my-tv-server",
  "version": "0.1.0",
  "description": "Personal TV tracking app - backend (NestJS + Prisma + PostgreSQL)",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "prisma generate && nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "postinstall": "prisma generate",
    "test": "jest",
    "import:tvtime": "ts-node import-tvtime/run.ts",
    "import:tvtime:dry-run": "ts-node import-tvtime/run.ts --dry-run",
    "trakt:backfill-tvtime-show-id": "ts-node trakt-enrichment/run-backfill.ts",
    "trakt:enrichment-dry-run": "ts-node trakt-enrichment/run-enrichment-dry-run.ts",
    "tmdb:enrichment-dry-run": "ts-node tmdb-enrichment/run-enrichment-dry-run.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv-parse": "^7.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.2",
    "dotenv": "^17.4.2",
    "jest": "^30.4.2",
    "prisma": "^5.22.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
