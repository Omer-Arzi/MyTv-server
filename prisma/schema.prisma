generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// The show's own public release status — provider-derived (TMDb/Trakt),
// never user-editable, never touched by watch activity. Distinct from
// UserSeriesProgress.userStatus, which tracks THIS user's personal
// relationship with a series. Defaults to UNKNOWN, not a confident guess:
// see docs/status-model-plan.md §3 for why "ongoing until enriched" was a
// real bug (every imported, never-enriched series claimed to be airing).
enum ReleaseStatus {
  UNKNOWN
  RETURNING
  ENDED
  CANCELLED
  IN_PRODUCTION
}

// This user's personal relationship with a series — separate from the
// series' own ReleaseStatus. Mostly user-controlled (WATCHLIST/PAUSED/
// DROPPED) or auto-derived from watch activity + episode catalog completeness
// (WATCHING/CAUGHT_UP/COMPLETED). See docs/status-model-plan.md §4 for the
// full derivation rules and which values come from where.
enum UserSeriesStatus {
  UNKNOWN
  WATCHLIST
  WATCHING
  PAUSED
  DROPPED
  CAUGHT_UP
  COMPLETED
}

enum ImportStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ImportIssueSeverity {
  INFO
  WARNING
  ERROR
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progress        UserSeriesProgress[]
  episodeWatches  EpisodeWatch[]
  watchlistItems  WatchlistItem[]
  episodeRatings  EpisodeRating[]
  episodeEmotions EpisodeEmotion[]
  seriesRatings   SeriesRating[]
  migrationHistory  MigrationHistory[]
  providerDecisions ProviderIdentityDecision[]
  libraryRefreshJobs LibraryRefreshJob[]
}

model Series {
  id            String        @id @default(uuid())
  title         String
  overview      String?
  posterUrl     String?
  // "Fanart"/backdrop-style wide image, distinct from posterUrl. Added for
  // Trakt enrichment — see docs/trakt-enrichment-plan.md §6.
  backdropUrl   String?
  releaseStatus ReleaseStatus @default(UNKNOWN)
  // Freeform bag for import-sourced fields with no dedicated column yet,
  // e.g. TV Time's internal tv_show_id. See docs/tvtime-data-audit.md §5.
  rawMetadata   Json?
  // Breadcrumb only (no relation) — which import run last touched this row.
  // See docs/mytv-prisma-schema-plan.md §3 for why this isn't a hard FK.
  importBatchId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  seasons        Season[]
  progress       UserSeriesProgress[]
  watchlistItems WatchlistItem[]
  externalIds    ExternalIds?
  ratings        SeriesRating[]
  migrationHistory  MigrationHistory[]
  providerDecisions ProviderIdentityDecision[]
  syncStatus        SeriesSyncStatus?
}

// Persistent catalog-sync metadata for the automatic episode-release-refresh
// scheduler (src/modules/sync-scheduler). Deliberately its own table rather
// than columns on Series — this is operational bookkeeping about *when we
// last checked the provider*, not series data itself, and keeping it
// separate means every other Series read in the app never has to select
// around scheduler-only columns. One row per series (not per user/series):
// catalog freshness is a series-level concern independent of which user(s)
// track it, matching Part 3 of the scheduler architecture task — refresh
// frequency is decided per the series' local UserSeriesProgress statuses at
// tick time, not stored here.
model SeriesSyncStatus {
  id       String @id @default(uuid())
  seriesId String @unique
  series   Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  // Set at the end of every attempt, success or failure alike.
  lastEpisodeRefreshAt     DateTime?
  lastEpisodeRefreshStatus String? // 'SUCCESS' | 'FAILURE' | 'BLOCKED_MANUAL_REVIEW'
  lastEpisodeRefreshError  String?
  // Set only on a genuinely successful attempt — distinct from
  // lastEpisodeRefreshAt so "last time we tried" and "last time it actually
  // worked" can be told apart at a glance.
  lastSuccessfulRefreshAt DateTime?
  // Set whenever the provider was actually called, even if the call itself
  // failed — distinct from lastEpisodeRefreshAt, which also covers
  // skip-without-calling-the-provider outcomes (e.g. not yet due).
  lastProviderCheckAt DateTime?
  // Consecutive failure count, reset to 0 on any success. Drives the
  // exponential backoff in sync-frequency-policy.ts's
  // computeNextEligibleRefreshAt.
  numberOfFailures Int @default(0)
  lastSyncDurationMs Int?

  // Denormalized so the scheduler's due-series query doesn't have to
  // recompute every series' interval from scratch on every tick — set to
  // (attempt time + smart-policy interval, or backoff delay after a
  // failure — see smart-scheduling-policy.ts).
  nextEligibleRefreshAt DateTime?

  // --- Added for the episode-and-series-update flow (Part 9) -------------
  // What triggered the MOST RECENT attempt (successful or not) — one of
  // SCHEDULED / MANUAL_SERIES / MANUAL_LIBRARY / SERIES_PAGE_STALE /
  // LOCAL_RELEASE_ACTIVATION. Plain string (not a Prisma enum reference on
  // this column, though SyncTrigger below IS a real enum) kept nullable so
  // a pre-existing row from before this migration reads as "unknown", not
  // a false SCHEDULED.
  lastRefreshTrigger SyncTrigger?

  // Duplicate-run / concurrency protection (Part 5/16). Claimed atomically
  // via an UPDATE ... WHERE refreshInProgress = false (see
  // SeriesRefreshOrchestratorService) — never trusted from a prior read.
  // refreshStartedAt lets a crashed/never-released lock be detected and
  // reclaimed after a timeout (restart-safety) rather than wedging a
  // series out of the schedule forever.
  refreshInProgress Boolean   @default(false)
  refreshStartedAt  DateTime?

  // When the last attempt actually found something to insert/change
  // (episodesAdded/seasonsAdded > 0), independent of lastEpisodeRefreshAt
  // (which updates on EVERY attempt, changed or not) — answers "when did
  // this series' catalog last actually change" (Part 9).
  lastChangeAt      DateTime?
  lastEpisodesAdded Int?
  lastSeasonsAdded  Int?
  // True when the last attempt's classification required manual review
  // (season shrink, suspicious bulk insert, etc. — see
  // classifyRefreshOperatingOutcome) rather than being auto-applied.
  lastRequiresManualReview Boolean @default(false)

  // Separate from lastEpisodeRefreshAt/lastProviderCheckAt (both of which
  // only ever update on a PROVIDER call) — set whenever
  // runLocalReleaseActivation (local-release-activation.ts) recomputes
  // this series' progress, provider call or not.
  lastLocalActivationAt DateTime?

  updatedAt DateTime @updatedAt

  @@index([nextEligibleRefreshAt])
  @@index([refreshInProgress])
}

// Suggested trigger values (Part 9) — one place both SeriesSyncStatus and
// LibraryRefreshJob draw from, so a log/UI reader never has to reconcile
// two separate trigger vocabularies.
enum SyncTrigger {
  SCHEDULED
  MANUAL_SERIES
  MANUAL_LIBRARY
  SERIES_PAGE_STALE
  LOCAL_RELEASE_ACTIVATION
}

enum LibraryRefreshJobStatus {
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
}

// User-level full-library refresh job (Part 9 — "do not overload one
// per-series row with insufficient aggregate job information"). One row
// per manual "Check for updates" run (Part 6); SeriesRefreshOrchestratorService
// updates the per-series SeriesSyncStatus rows as it goes, while THIS row
// tracks the aggregate job itself — what the Settings screen polls for
// progress/summary. Never more than one RUNNING row per user at a time —
// enforced at the service layer (LibraryRefreshJobService), not a DB
// constraint (see that service's doc comment for the accepted race-window
// tradeoff on a single-instance, single-real-user app).
model LibraryRefreshJob {
  id           String                  @id @default(uuid())
  userId       String
  status       LibraryRefreshJobStatus @default(RUNNING)
  triggeredBy  SyncTrigger
  startedAt    DateTime                @default(now())
  finishedAt   DateTime?

  totalSeries           Int
  checkedSeries         Int @default(0)
  seriesWithNewEpisodes Int @default(0)
  seriesWithNewSeasons  Int @default(0)
  seriesFailed          Int @default(0)
  seriesManualReview    Int @default(0)

  // Local-release-activation counts for this job's final whole-library
  // pass (Part 6.5) — kept alongside the per-series provider-refresh
  // counts above rather than conflated with them, since they come from a
  // genuinely separate process (see local-release-activation.ts).
  seriesActivatedLocally Int @default(0)

  lastError String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([userId, status])
}

model Season {
  id            String  @id @default(uuid())
  seriesId      String
  seasonNumber  Int
  title         String?
  // TV Time has nothing season-level to enrich beyond seasonNumber/title, so
  // Season didn't get these in the original import schema pass. Trakt does
  // have season-level data (overview, poster, its own season id) — added for
  // consistency with every other enrichable model. See
  // docs/trakt-enrichment-plan.md §6.
  rawMetadata   Json?
  importBatchId String?

  series   Series    @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  episodes Episode[]

  @@unique([seriesId, seasonNumber])
}

model Episode {
  id             String    @id @default(uuid())
  seasonId       String
  episodeNumber  Int
  // Nullable: TV Time's export carries no episode titles/overviews/air dates
  // at all (docs/tvtime-data-audit.md §5) — imported episodes stay null here
  // rather than getting an invented placeholder, until Trakt backfills them.
  title          String?
  overview       String?
  airDate        DateTime?
  runtimeMinutes Int?
  // A rendering-critical field (used directly in an <img> tag), not an
  // unmapped/archival one — belongs in a real column rather than
  // rawMetadata, unlike e.g. TV Time's bulk_type or Trakt's raw candidate
  // list. See docs/trakt-enrichment-plan.md §6 gap #4.
  imageUrl       String?
  rawMetadata    Json?
  importBatchId  String?

  season   Season           @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  watches  EpisodeWatch[]
  ratings  EpisodeRating[]
  emotions EpisodeEmotion[]

  // Episodes that some UserSeriesProgress currently points to as "next episode to watch"
  progressPointingHere UserSeriesProgress[] @relation("NextEpisode")

  @@unique([seasonId, episodeNumber])
}

// One row per (user, series) the user has ANY relationship with — watchlisted,
// watching, paused, dropped, caught up, or completed (docs/status-model-plan.md
// §4 — no longer conditional on having watched something, unlike the original
// design). Also caches the next episode to watch so /me/watch-next and the
// "mark watched" response are cheap, deterministic reads instead of
// recomputed on every request.
model UserSeriesProgress {
  id            String           @id @default(uuid())
  userId        String
  seriesId      String
  userStatus    UserSeriesStatus @default(UNKNOWN)
  lastWatchedAt DateTime?
  nextEpisodeId String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  series      Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  nextEpisode Episode? @relation("NextEpisode", fields: [nextEpisodeId], references: [id])

  @@unique([userId, seriesId])
  @@index([userId, userStatus, lastWatchedAt])
}

// A single watched-episode event. Unique per (user, episode) — re-watch
// *event* tracking is still out of scope for V1, marking watched again just
// updates it. rewatchCount preserves the "how many times" signal TV Time
// carries without modeling full rewatch history (docs/mytv-prisma-schema-plan.md §4).
// SINGLE — a deliberate, individual "mark this one episode watched" action
// (POST /episodes/:episodeId/watch — the V/check action and the swipe
// action both funnel into this same endpoint), always visible in Recently
// Watched. BATCH — created by the "mark all released" bulk escape hatch
// (POST /seasons/:seasonId/watch-all, POST /series/:seriesId/watch-all-released
// — watch-all-logic.ts), hidden from Recently Watched (see
// MeService.getRecentlyWatched) but otherwise a completely normal
// EpisodeWatch row: counted in progress/completion, next-episode
// derivation, and every other place that reads watch history. Defaulted to
// SINGLE so existing rows (including TV Time import history, which writes
// EpisodeWatch directly and is unaffected by this field) keep their
// current Recently Watched visibility unchanged.
enum WatchSource {
  SINGLE
  BATCH
}

model EpisodeWatch {
  id                   String      @id @default(uuid())
  userId               String
  episodeId            String
  watchedAt            DateTime    @default(now())
  // True when watchedAt is a rough guess rather than a real date — e.g. TV
  // Time's bulk "mark previous episodes watched" action stamps many episodes
  // with one timestamp (docs/tvtime-data-audit.md §3.1). Lets the UI show
  // "date approximate" instead of presenting a guess as fact.
  watchDateApproximate Boolean     @default(false)
  rewatchCount         Int         @default(0)
  rawMetadata          Json?
  importBatchId        String?
  watchSource          WatchSource @default(SINGLE)

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode      @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  note    EpisodeNote?

  @@unique([userId, episodeId])
  @@index([userId, watchedAt])
}

model EpisodeNote {
  id             String   @id @default(uuid())
  episodeWatchId String   @unique
  text           String
  // Social metadata from imported TV Time comments that has no MyTv
  // equivalent (likes, spoiler flag, twitter/fb cross-post) — preserved
  // here rather than dropped. See docs/tvtime-data-audit.md §3.5.
  rawMetadata    Json?
  importBatchId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  episodeWatch EpisodeWatch @relation(fields: [episodeWatchId], references: [id], onDelete: Cascade)
}

model WatchlistItem {
  id            String   @id @default(uuid())
  userId        String
  seriesId      String
  addedAt       DateTime @default(now())
  // Which reconciled TV Time source(s) this came from, for traceability if a
  // reconciliation later turns out wrong. See docs/tvtime-data-audit.md §3.6.
  rawMetadata   Json?
  importBatchId String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId])
}

// A user's rating for one episode. TV Time's rating scale is not confirmed
// from the export alone (docs/tvtime-data-audit.md §3.3) — rawValue is
// stored as received; normalizedValue is filled in later, once the scale is
// confirmed, without a migration.
model EpisodeRating {
  id              String   @id @default(uuid())
  userId          String
  episodeId       String
  rawValue        Int
  normalizedValue Decimal? @db.Decimal(3, 1)
  rawMetadata     Json?
  importBatchId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([episodeId])
}

// A user's emotional reaction(s) to one episode. Unlike ratings, TV Time
// allows more than one reaction per episode, so this is not unique per
// (userId, episodeId) alone. See docs/tvtime-data-audit.md §3.4.
model EpisodeEmotion {
  id                String   @id @default(uuid())
  userId            String
  episodeId         String
  rawValue          Int
  normalizedEmotion String?
  rawMetadata       Json?
  importBatchId     String?
  createdAt         DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId, rawValue])
  @@index([episodeId])
}

// Whole-series rating (tv_show_rate.csv) — a different feature from episode
// ratings. Unlike them this one IS on a known, decoded scale (observed
// values like "4.50", "5" on a 0-5 scale), so it gets a real Decimal value
// from day one instead of a rawValue/normalizedValue pair.
model SeriesRating {
  id            String   @id @default(uuid())
  userId        String
  seriesId      String
  value         Decimal  @db.Decimal(3, 2)
  rawMetadata   Json?
  importBatchId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId])
  @@index([seriesId])
}

// External metadata provider ids for a series (Trakt/TMDB/IMDB), for the
// future Trakt integration. Not populated/used yet. TV Time's own internal
// ids are NOT stored here (different provider, different meaning) — they go
// in Series.rawMetadata / Episode.rawMetadata instead.
//
// traktId/tmdbId/imdbId stay as specific, uniquely-constrained columns
// (queryable, one per provider). provider/providerId are a generic layer on
// top recording which provider's match *established* this row in the first
// place — e.g. provider="trakt", providerId=<trakt's id>, matching traktId
// today — so a future non-Trakt-first matching path has somewhere to record
// "matched via X" without another schema change. matchConfidence/matchSource/
// matchedAt/rawMetadata record *how* the match was made (score, algorithm vs
// manual correction, when, full raw candidate/scoring detail) — see
// docs/trakt-enrichment-plan.md §6 gap #3.
model ExternalIds {
  id       String  @id @default(uuid())
  seriesId String  @unique
  traktId  String? @unique
  tmdbId   String? @unique
  imdbId   String? @unique

  provider        String?
  providerId      String?
  matchConfidence Float?
  matchSource     String?
  matchedAt       DateTime?
  rawMetadata     Json?

  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)
}

// The runtime-safe, per-user source of truth for "which provider identity
// has a human explicitly confirmed for this series" — replaces
// library-health/provider-confirmation-decisions.json as the LIVE decision
// store (the JSON file's historical entries are one-time backfilled into
// this table; see library-health/run-backfill-provider-decisions.ts). Both
// the CLI pipeline and the in-app Migration Workbench read from this same
// table now, so the two can never disagree about which titles have a
// confirmed decision. @@unique([userId, seriesId]) mirrors
// UserSeriesProgress's own per-user-per-series uniqueness — a decision is
// scoped to the user who made it, never shared across users.
model ProviderIdentityDecision {
  id       String @id @default(uuid())
  userId   String
  seriesId String

  // 'confirm' | 'skip' | 'defer' — mirrors
  // library-health/provider-confirmation-decisions-logic.ts's
  // ProviderConfirmationDecisionType exactly; kept as a plain String (not a
  // Prisma enum) so the decision vocabulary stays defined in one place
  // (that TS file), not duplicated into the schema.
  decision   String
  provider   String?
  providerId String?

  // Both mirror provider-confirmation-decisions.json's own optional
  // per-title migration escape hatch — see migration-confirmation-logic.ts.
  migrationIntent Boolean @default(false)
  statusOverride  String?
  notes           String?

  // 'cli-decisions-file' for every row backfilled from the JSON file,
  // 'app-confirmation' for a decision made through the in-app provider
  // search flow — lets a reader tell which workflow produced a row without
  // guessing from other fields.
  source String

  // The candidate's confidence at decision time, normalized 0..1 — the
  // SAME canonical scale as ProviderCandidateDto.confidenceScore and
  // ConfirmIdentityDto.confidence (see search-provider-candidates-for-series.ts's
  // normalizeConfidenceScore — the one place a 0-100 raw score is ever
  // converted to this 0..1 domain representation). Lets a future audit
  // flag a decision as possibly stale if the local title changes enough
  // that the original confidence no longer applies. Null for
  // JSON-backfilled rows where this wasn't recorded.
  confidence Float?

  // Explicit, human-reviewed acknowledgment that THIS series' specific
  // season-shrink/renumbering pattern has been checked and approved to
  // migrate anyway, preserving every orphan untouched — see
  // classifyMigrationConfirmation's realSeasonShrinkDetected hard floor
  // (library-health/migration-confirmation-logic.ts). Deliberately
  // SEPARATE from migrationIntent: migrationIntent alone can never bypass
  // that floor (that is the floor's entire purpose — added after an audit
  // found migrationIntent could otherwise mask a genuine numbering-
  // collision risk). This is the one narrow, explicit, per-decision
  // override for it — never implied, never batch-defaulted, never
  // inferred from any other field. The title/year identity sanity check
  // remains completely non-bypassable regardless of this flag.
  seasonShrinkReviewed Boolean @default(false)

  decidedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId])
  @@index([userId, decision])
}

// A durable, auditable record of exactly one Migration Workbench apply —
// created inside the same transaction as the write it describes (see
// library-health/run-provider-confirmation-for-decision.ts), so a
// successful apply can never exist without a matching history row. Stores
// enough before/after state to build a rollback plan without re-deriving
// it from scratch later (see library-health/migration-rollback-logic.ts) —
// "prefer storing a recovery plan... rather than trying to infer rollback
// later." Complex before/after shapes are stored as Json (matching
// Series.rawMetadata's existing convention) rather than fully normalized
// into columns, keeping this table additive and simple.
model MigrationHistory {
  id           String   @id @default(uuid())
  userId       String
  seriesId     String
  seriesTitle  String
  appliedAt    DateTime @default(now())

  // The MigrationOperatingClassification this apply was authorized under
  // (AUTO_MIGRATE/AUTO_REFRESH/etc.) and the Workbench category it was
  // surfaced in at the time — both plain strings, same reasoning as
  // ProviderIdentityDecision.decision above.
  classification String
  sourceCategory String

  // { provider, providerId, tmdbId } | null — null "before" means no prior
  // confirmed match existed (first-time confirmation).
  providerBefore Json?
  providerAfter  Json

  releaseStatusBefore String?
  releaseStatusAfter  String?

  userStatusBefore    String
  userStatusAfter     String
  nextEpisodeIdBefore String?
  nextEpisodeIdAfter  String?

  // Episode.id[] — every episode this migration inserted. Rollback may
  // only ever remove episodes from this exact list (see rollback scope
  // rules), never any other row.
  episodesInsertedIds Json
  // Episode.id[] — every episode whose metadata (title/overview/airDate/
  // runtime) this migration backfilled in place. Never rolled back (no
  // prior-value snapshot exists for these — see rollback documentation).
  episodesUpdatedIds Json
  // Episode.id[] — every watched-but-provider-unmatched episode this
  // migration guaranteed to leave untouched. Recorded for the audit trail
  // even though, by construction, these were never written to.
  preservedOrphanEpisodeIds Json
  // matchedWatchedCount at apply time — how many locally-watched episodes
  // this migration's watch-history mapping covered.
  watchedMappingCount Int

  verificationPassed Boolean
  // Failed verification check names/details, if any — [] when verificationPassed is true.
  verificationDetail Json

  // Set only once a rollback of this migration succeeds — null means
  // "never rolled back" (the default, and the only state that permits a
  // future rollback attempt at all).
  rolledBackAt DateTime?
  // Human-readable reason recorded at rollback time (mirrors migration
  // apply's own reason-string convention throughout this codebase).
  rollbackReason String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@index([userId, seriesId])
  @@index([userId, appliedAt])
}

// --- Import bookkeeping ---------------------------------------------------
// Fully separate from the app models above: nothing here is referenced by a
// hard @relation from Series/Episode/EpisodeWatch/etc — those only carry a
// loose importBatchId breadcrumb. See docs/mytv-prisma-schema-plan.md §6.

// One row per importer run. skippedFiles records which source files were
// excluded wholesale (sensitive data — docs/tvtime-data-audit.md §4) for
// this run, so the policy is auditable per-batch, not just documented in prose.
model ImportBatch {
  id           String       @id @default(uuid())
  source       String
  status       ImportStatus @default(PENDING)
  startedAt    DateTime     @default(now())
  finishedAt   DateTime?
  // [{ file: string, reason: string }]
  skippedFiles Json?
  notes        String?

  rawRows ImportRawRow[]
  issues  ImportIssue[]
}

// One row per source CSV row that was imported (i.e. NOT one of the
// wholesale-excluded sensitive files). payload is the raw row, untyped and
// unmodified. resolvedEntityType/Id are filled in by the transform pass once
// it decides what this row became — the queryable "which raw rows fed this
// app row" direction, since many raw rows can resolve to one app row (e.g.
// the same watch logged in both tracking-prod-records.csv and
// tracking-prod-records-v2.csv — docs/tvtime-data-audit.md §3.1).
model ImportRawRow {
  id                 String    @id @default(uuid())
  importBatchId      String
  sourceFile         String
  sourceRowNumber    Int
  payload            Json
  resolvedEntityType String?
  resolvedEntityId   String?
  processedAt        DateTime?
  createdAt          DateTime  @default(now())

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@index([importBatchId, sourceFile])
  @@index([resolvedEntityType, resolvedEntityId])
}

// Anything the transform pass couldn't resolve automatically — ambiguous
// series-name duplicates, watchlist source conflicts, comments with no
// matching watch event, count-mismatch sanity-check failures, etc. Mirrors
// needs-review.json from docs/tvtime-data-audit.md §7.5, but queryable and
// tied to a specific batch/row instead of being a flat file.
model ImportIssue {
  id                String              @id @default(uuid())
  importBatchId     String
  severity          ImportIssueSeverity
  sourceFile        String?
  sourceRowNumber   Int?
  relatedEntityType String?
  relatedEntityId   String?
  message           String
  resolved          Boolean             @default(false)
  createdAt         DateTime            @default(now())

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

