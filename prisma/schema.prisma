generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// The show's own broadcast status (from metadata / future Trakt sync).
// Distinct from UserSeriesProgress.status, which tracks THIS user's watch progress.
enum SeriesStatus {
  ONGOING
  ENDED
  CANCELED
}

// This user's personal progress through a series.
enum ProgressStatus {
  WATCHING
  COMPLETED
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progress       UserSeriesProgress[]
  episodeWatches EpisodeWatch[]
  watchlistItems WatchlistItem[]
}

model Series {
  id        String       @id @default(uuid())
  title     String
  overview  String?
  posterUrl String?
  status    SeriesStatus @default(ONGOING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  seasons        Season[]
  progress       UserSeriesProgress[]
  watchlistItems WatchlistItem[]
  externalIds    ExternalIds?
}

model Season {
  id           String  @id @default(uuid())
  seriesId     String
  seasonNumber Int
  title        String?

  series   Series    @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  episodes Episode[]

  @@unique([seriesId, seasonNumber])
}

model Episode {
  id             String    @id @default(uuid())
  seasonId       String
  episodeNumber  Int
  title          String
  overview       String?
  airDate        DateTime?
  runtimeMinutes Int?

  season  Season         @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  watches EpisodeWatch[]

  // Episodes that some UserSeriesProgress currently points to as "next episode to watch"
  progressPointingHere UserSeriesProgress[] @relation("NextEpisode")

  @@unique([seasonId, episodeNumber])
}

// One row per (user, series). Tracks the user's overall progress and caches
// the next episode to watch so /me/watch-next and the "mark watched" response
// are cheap, deterministic reads instead of recomputed on every request.
model UserSeriesProgress {
  id            String         @id @default(uuid())
  userId        String
  seriesId      String
  status        ProgressStatus @default(WATCHING)
  lastWatchedAt DateTime?
  nextEpisodeId String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  series      Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  nextEpisode Episode? @relation("NextEpisode", fields: [nextEpisodeId], references: [id])

  @@unique([userId, seriesId])
  @@index([userId, status, lastWatchedAt])
}

// A single watched-episode event. Unique per (user, episode) — re-watch
// tracking is out of scope for V1, marking watched again just updates it.
model EpisodeWatch {
  id        String   @id @default(uuid())
  userId    String
  episodeId String
  watchedAt DateTime @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode      @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  note    EpisodeNote?

  @@unique([userId, episodeId])
  @@index([userId, watchedAt])
}

model EpisodeNote {
  id             String   @id @default(uuid())
  episodeWatchId String   @unique
  text           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  episodeWatch EpisodeWatch @relation(fields: [episodeWatchId], references: [id], onDelete: Cascade)
}

model WatchlistItem {
  id       String   @id @default(uuid())
  userId   String
  seriesId String
  addedAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId])
}

// External metadata provider ids for a series (Trakt/TMDB/IMDB), for the
// future Trakt integration. Not populated/used yet.
model ExternalIds {
  id       String  @id @default(uuid())
  seriesId String  @unique
  traktId  String? @unique
  tmdbId   String? @unique
  imdbId   String? @unique

  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)
}
