generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// The show's own public release status — provider-derived (TMDb/Trakt),
// never user-editable, never touched by watch activity. Distinct from
// UserSeriesProgress.userStatus, which tracks THIS user's personal
// relationship with a series. Defaults to UNKNOWN, not a confident guess:
// see docs/status-model-plan.md §3 for why "ongoing until enriched" was a
// real bug (every imported, never-enriched series claimed to be airing).
enum ReleaseStatus {
  UNKNOWN
  RETURNING
  ENDED
  CANCELLED
  IN_PRODUCTION
}

// This user's personal relationship with a series — separate from the
// series' own ReleaseStatus. Mostly user-controlled (WATCHLIST/PAUSED/
// DROPPED) or auto-derived from watch activity + episode catalog completeness
// (WATCHING/CAUGHT_UP/COMPLETED). See docs/status-model-plan.md §4 for the
// full derivation rules and which values come from where.
enum UserSeriesStatus {
  UNKNOWN
  WATCHLIST
  WATCHING
  PAUSED
  DROPPED
  CAUGHT_UP
  COMPLETED
}

enum ImportStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ImportIssueSeverity {
  INFO
  WARNING
  ERROR
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progress        UserSeriesProgress[]
  episodeWatches  EpisodeWatch[]
  watchlistItems  WatchlistItem[]
  episodeRatings  EpisodeRating[]
  episodeEmotions EpisodeEmotion[]
  seriesRatings   SeriesRating[]
}

model Series {
  id            String        @id @default(uuid())
  title         String
  overview      String?
  posterUrl     String?
  // "Fanart"/backdrop-style wide image, distinct from posterUrl. Added for
  // Trakt enrichment — see docs/trakt-enrichment-plan.md §6.
  backdropUrl   String?
  releaseStatus ReleaseStatus @default(UNKNOWN)
  // Freeform bag for import-sourced fields with no dedicated column yet,
  // e.g. TV Time's internal tv_show_id. See docs/tvtime-data-audit.md §5.
  rawMetadata   Json?
  // Breadcrumb only (no relation) — which import run last touched this row.
  // See docs/mytv-prisma-schema-plan.md §3 for why this isn't a hard FK.
  importBatchId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  seasons        Season[]
  progress       UserSeriesProgress[]
  watchlistItems WatchlistItem[]
  externalIds    ExternalIds?
  ratings        SeriesRating[]
}

model Season {
  id            String  @id @default(uuid())
  seriesId      String
  seasonNumber  Int
  title         String?
  // TV Time has nothing season-level to enrich beyond seasonNumber/title, so
  // Season didn't get these in the original import schema pass. Trakt does
  // have season-level data (overview, poster, its own season id) — added for
  // consistency with every other enrichable model. See
  // docs/trakt-enrichment-plan.md §6.
  rawMetadata   Json?
  importBatchId String?

  series   Series    @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  episodes Episode[]

  @@unique([seriesId, seasonNumber])
}

model Episode {
  id             String    @id @default(uuid())
  seasonId       String
  episodeNumber  Int
  // Nullable: TV Time's export carries no episode titles/overviews/air dates
  // at all (docs/tvtime-data-audit.md §5) — imported episodes stay null here
  // rather than getting an invented placeholder, until Trakt backfills them.
  title          String?
  overview       String?
  airDate        DateTime?
  runtimeMinutes Int?
  // A rendering-critical field (used directly in an <img> tag), not an
  // unmapped/archival one — belongs in a real column rather than
  // rawMetadata, unlike e.g. TV Time's bulk_type or Trakt's raw candidate
  // list. See docs/trakt-enrichment-plan.md §6 gap #4.
  imageUrl       String?
  rawMetadata    Json?
  importBatchId  String?

  season   Season           @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  watches  EpisodeWatch[]
  ratings  EpisodeRating[]
  emotions EpisodeEmotion[]

  // Episodes that some UserSeriesProgress currently points to as "next episode to watch"
  progressPointingHere UserSeriesProgress[] @relation("NextEpisode")

  @@unique([seasonId, episodeNumber])
}

// One row per (user, series) the user has ANY relationship with — watchlisted,
// watching, paused, dropped, caught up, or completed (docs/status-model-plan.md
// §4 — no longer conditional on having watched something, unlike the original
// design). Also caches the next episode to watch so /me/watch-next and the
// "mark watched" response are cheap, deterministic reads instead of
// recomputed on every request.
model UserSeriesProgress {
  id            String           @id @default(uuid())
  userId        String
  seriesId      String
  userStatus    UserSeriesStatus @default(UNKNOWN)
  lastWatchedAt DateTime?
  nextEpisodeId String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  series      Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  nextEpisode Episode? @relation("NextEpisode", fields: [nextEpisodeId], references: [id])

  @@unique([userId, seriesId])
  @@index([userId, userStatus, lastWatchedAt])
}

// A single watched-episode event. Unique per (user, episode) — re-watch
// *event* tracking is still out of scope for V1, marking watched again just
// updates it. rewatchCount preserves the "how many times" signal TV Time
// carries without modeling full rewatch history (docs/mytv-prisma-schema-plan.md §4).
model EpisodeWatch {
  id                   String   @id @default(uuid())
  userId               String
  episodeId            String
  watchedAt            DateTime @default(now())
  // True when watchedAt is a rough guess rather than a real date — e.g. TV
  // Time's bulk "mark previous episodes watched" action stamps many episodes
  // with one timestamp (docs/tvtime-data-audit.md §3.1). Lets the UI show
  // "date approximate" instead of presenting a guess as fact.
  watchDateApproximate Boolean  @default(false)
  rewatchCount         Int      @default(0)
  rawMetadata          Json?
  importBatchId        String?

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode      @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  note    EpisodeNote?

  @@unique([userId, episodeId])
  @@index([userId, watchedAt])
}

model EpisodeNote {
  id             String   @id @default(uuid())
  episodeWatchId String   @unique
  text           String
  // Social metadata from imported TV Time comments that has no MyTv
  // equivalent (likes, spoiler flag, twitter/fb cross-post) — preserved
  // here rather than dropped. See docs/tvtime-data-audit.md §3.5.
  rawMetadata    Json?
  importBatchId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  episodeWatch EpisodeWatch @relation(fields: [episodeWatchId], references: [id], onDelete: Cascade)
}

model WatchlistItem {
  id            String   @id @default(uuid())
  userId        String
  seriesId      String
  addedAt       DateTime @default(now())
  // Which reconciled TV Time source(s) this came from, for traceability if a
  // reconciliation later turns out wrong. See docs/tvtime-data-audit.md §3.6.
  rawMetadata   Json?
  importBatchId String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId])
}

// A user's rating for one episode. TV Time's rating scale is not confirmed
// from the export alone (docs/tvtime-data-audit.md §3.3) — rawValue is
// stored as received; normalizedValue is filled in later, once the scale is
// confirmed, without a migration.
model EpisodeRating {
  id              String   @id @default(uuid())
  userId          String
  episodeId       String
  rawValue        Int
  normalizedValue Decimal? @db.Decimal(3, 1)
  rawMetadata     Json?
  importBatchId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([episodeId])
}

// A user's emotional reaction(s) to one episode. Unlike ratings, TV Time
// allows more than one reaction per episode, so this is not unique per
// (userId, episodeId) alone. See docs/tvtime-data-audit.md §3.4.
model EpisodeEmotion {
  id                String   @id @default(uuid())
  userId            String
  episodeId         String
  rawValue          Int
  normalizedEmotion String?
  rawMetadata       Json?
  importBatchId     String?
  createdAt         DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId, rawValue])
  @@index([episodeId])
}

// Whole-series rating (tv_show_rate.csv) — a different feature from episode
// ratings. Unlike them this one IS on a known, decoded scale (observed
// values like "4.50", "5" on a 0-5 scale), so it gets a real Decimal value
// from day one instead of a rawValue/normalizedValue pair.
model SeriesRating {
  id            String   @id @default(uuid())
  userId        String
  seriesId      String
  value         Decimal  @db.Decimal(3, 2)
  rawMetadata   Json?
  importBatchId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId])
  @@index([seriesId])
}

// External metadata provider ids for a series (Trakt/TMDB/IMDB), for the
// future Trakt integration. Not populated/used yet. TV Time's own internal
// ids are NOT stored here (different provider, different meaning) — they go
// in Series.rawMetadata / Episode.rawMetadata instead.
//
// traktId/tmdbId/imdbId stay as specific, uniquely-constrained columns
// (queryable, one per provider). provider/providerId are a generic layer on
// top recording which provider's match *established* this row in the first
// place — e.g. provider="trakt", providerId=<trakt's id>, matching traktId
// today — so a future non-Trakt-first matching path has somewhere to record
// "matched via X" without another schema change. matchConfidence/matchSource/
// matchedAt/rawMetadata record *how* the match was made (score, algorithm vs
// manual correction, when, full raw candidate/scoring detail) — see
// docs/trakt-enrichment-plan.md §6 gap #3.
model ExternalIds {
  id       String  @id @default(uuid())
  seriesId String  @unique
  traktId  String? @unique
  tmdbId   String? @unique
  imdbId   String? @unique

  provider        String?
  providerId      String?
  matchConfidence Float?
  matchSource     String?
  matchedAt       DateTime?
  rawMetadata     Json?

  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)
}

// --- Import bookkeeping ---------------------------------------------------
// Fully separate from the app models above: nothing here is referenced by a
// hard @relation from Series/Episode/EpisodeWatch/etc — those only carry a
// loose importBatchId breadcrumb. See docs/mytv-prisma-schema-plan.md §6.

// One row per importer run. skippedFiles records which source files were
// excluded wholesale (sensitive data — docs/tvtime-data-audit.md §4) for
// this run, so the policy is auditable per-batch, not just documented in prose.
model ImportBatch {
  id           String       @id @default(uuid())
  source       String
  status       ImportStatus @default(PENDING)
  startedAt    DateTime     @default(now())
  finishedAt   DateTime?
  // [{ file: string, reason: string }]
  skippedFiles Json?
  notes        String?

  rawRows ImportRawRow[]
  issues  ImportIssue[]
}

// One row per source CSV row that was imported (i.e. NOT one of the
// wholesale-excluded sensitive files). payload is the raw row, untyped and
// unmodified. resolvedEntityType/Id are filled in by the transform pass once
// it decides what this row became — the queryable "which raw rows fed this
// app row" direction, since many raw rows can resolve to one app row (e.g.
// the same watch logged in both tracking-prod-records.csv and
// tracking-prod-records-v2.csv — docs/tvtime-data-audit.md §3.1).
model ImportRawRow {
  id                 String    @id @default(uuid())
  importBatchId      String
  sourceFile         String
  sourceRowNumber    Int
  payload            Json
  resolvedEntityType String?
  resolvedEntityId   String?
  processedAt        DateTime?
  createdAt          DateTime  @default(now())

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@index([importBatchId, sourceFile])
  @@index([resolvedEntityType, resolvedEntityId])
}

// Anything the transform pass couldn't resolve automatically — ambiguous
// series-name duplicates, watchlist source conflicts, comments with no
// matching watch event, count-mismatch sanity-check failures, etc. Mirrors
// needs-review.json from docs/tvtime-data-audit.md §7.5, but queryable and
// tied to a specific batch/row instead of being a flat file.
model ImportIssue {
  id                String              @id @default(uuid())
  importBatchId     String
  severity          ImportIssueSeverity
  sourceFile        String?
  sourceRowNumber   Int?
  relatedEntityType String?
  relatedEntityId   String?
  message           String
  resolved          Boolean             @default(false)
  createdAt         DateTime            @default(now())

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@index([importBatchId, resolved])
  @@index([relatedEntityType, relatedEntityId])
}
